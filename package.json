{
  "name": "@ravshansbox/pg-migrate",
  "version": "0.12.0",
  "type": "module",
  "author": "Ravshan Samandarov",
  "license": "MIT",
  "description": "PostgreSQL Migration tool for NodeJS",
  "keywords": [
    "database",
    "postgresql",
    "migration",
    "nodejs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravshansbox/pg-migrate.git"
  },
  "bin": {
    "pg-migrate": "dist/esm/bin/migrate.js"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": ["package.json", "package-lock.json"],
          "message": "chore: release ${nextRelease.version}\n\n[skip ci]"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run post-build && chmod +x dist/esm/bin/migrate.js",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist",
    "format": "prettier --ignore-unknown --write .",
    "post-build": "node scripts/post-build.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.0.1",
    "@types/pg": "^8.16.0",
    "prettier": "^3.7.4",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
